{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{if .Root}}(Admin) {{end}}{{.Folder}}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "diamond",
          "leading_diamond": " ",
          "template": "\u2800{{ if .WSL }}WSL at {{ end }}{{.Icon}} ",
          "foreground": "#3A86FF",
          "background": "transparent",
          "type": "os"
        },
        {
          "properties": {
            "mapped_locations": {
              "C:\\temp": "\ue799"
            },
            "style": "agnoster_full"
          },
          "style": "plain",
          "template": "\u2800\ue5ff {{ .Path }} ",
          "foreground": "#33DD2D",
          "background": "transparent",
          "type": "path"
        },
        {
          "type": "git",
          "style": "powerline",
          "foreground": "#3A86FF",
          "background": "transparent",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FFEB3B{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#FFCC80{{ end }}",
            "{{ if gt .Ahead 0 }}#B388FF{{ end }}",
            "{{ if gt .Behind 0 }}#B388FB{{ end }}"
          ],
          "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}",
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "untracked_modes": {
              "/Users/user/Projects/oh-my-posh/": "no"
            },
            "source": "cli",
            "mapped_branches": {
              "feature/*": "🚀 feature/",
              "squad/*": "🤖 ",
              "master": "❌ master",
              "bug/*": "🐛 "
            }
          }
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#5c3bf5",
          "background": "transparent",
          "template": " \udb82\udeae {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} "
        },
        {
          "style": "powerline",
          "template": "\u2800\ue718\u2800{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}\u2800",
          "foreground": "transparent",
          "powerline_symbol": "\ue0b0",
          "background": "#6CA35E",
          "type": "node"
        },
        {
          "style": "powerline",
          "template": "\u2800\ue738\u2800{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}\u2800",
          "foreground": "#4063D8",
          "powerline_symbol": "\ue0b0",
          "background": "transparent",
          "type": "java"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "copilot",
          "foreground": "#2e9090",
          "background": "transparent",
          "template": "  {{ .Premium.Percent.Gauge }} ",
          "cache": {
            "duration": "5m",
            "strategy": "session"
          },
          "options": {
            "http_timeout": 1000
          }
        },
        {
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "diamond",
          "template": " {{ .CurrentDate | date .Format }} ",
          "foreground": "#2e9090",
          "background": "transparent",
          "type": "time"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "root_icon": "\uf0e7"
          },
          "style": "plain",
          "template": " \uf0e7 ",
          "foreground": "#ffff66",
          "type": "root"
        },
        {
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": " ❯ ",
          "foreground": "#00897b",
          "type": "exit",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#e91e63{{ end }}"
          ]
        }
      ],
      "newline": true
    }
  ],
  "version": 3,
  "final_space": true
}
